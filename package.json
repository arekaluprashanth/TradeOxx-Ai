{
  "name": "tradespaceai",
  "version": "1.0.0",
  "description": "Full-stack trading application with real-time market data",
  "type": "module",
  "scripts": {
    "install:all": "npm install && npm --prefix backend install && npm --prefix client install",
    "dev": "concurrently \"npm --prefix backend run dev\" \"npm --prefix client run dev\"",
    "dev:server": "npm --prefix backend run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "npm --prefix backend start",
    "prod": "npm run build && npm run start",
    "android:init": "npx cap init com.tradesphere.ai TradeSphereAI --web-dir=client/dist",
    "android:add": "npx cap add android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android"
  },
  "keywords": [
    "trading",
    "ai",
    "market",
    "portfolio"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.8.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0"
  }
}
